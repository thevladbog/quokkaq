# Copy to .env.demo and replace secrets + public hostnames.
# Domains must resolve to this VM before TLS (Let's Encrypt) succeeds.

# --- Public hostnames (no protocol) ---
DEMO_APP_HOST=app.demo.example.com
DEMO_API_HOST=api.demo.example.com
DEMO_S3_HOST=s3.demo.example.com

ACME_EMAIL=ops@example.com

# --- Images ---
# Product frontend image (registry tag you publish for demo).
DEMO_FRONTEND_IMAGE=cr.yandex/REGISTRY_ID/quokkaq-frontend:demo
# Optional override after local build:
# DEMO_BACKEND_IMAGE=quokkaq-backend-demo:local

# --- Postgres / Redis / MinIO ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=quokkaq
REDIS_PASSWORD=change-me-redis
# GID of the host docker socket group so demo-scheduler can run docker compose (profile scheduler). On the VM: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio
AWS_S3_BUCKET=quokkaq-materials

# --- App ---
JWT_SECRET=change-me-jwt-64chars-minimum-recommended-length

# SMTP optional (empty = skipped in health / non-fatal).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false

# --- Demo seed (used by /app/seed-demo inside backend container after reset) ---
# Set strong values via CI/GitHub Actions secrets or this file — do not rely on built-in demo defaults in production-facing demos.
# DEMO_HISTORY_DAYS=90
# DEMO_ADMIN_EMAIL=demo-admin@demo.quokkaq.local
DEMO_ADMIN_PASSWORD=
# DEMO_OPERATOR_EMAIL=demo-operator@demo.quokkaq.local
DEMO_OPERATOR_PASSWORD=
# DEMO_UNIT_TIMEZONE=Europe/Moscow
