# Base URL of the Go API: server-side fetch (plans) and browser lead form (POST /public/leads/request).
# Prefer MARKETING_API_URL in production for server-only fetch so the API URL is not required in the client bundle.
# If unset, NEXT_PUBLIC_API_URL is used. CORS on the API must allow this marketing origin.
# MARKETING_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Canonical origin of this marketing site (no trailing slash). Used for metadata, OG URLs, sitemap, and hreflang.
# In development, if unset, http://localhost:3010 is used. On Vercel, VERCEL_URL is used when this is unset.
# NEXT_PUBLIC_MARKETING_SITE_URL=https://quokkaq.com

# Base URL of the product web app (signup links on the pricing block).
# If unset, CTAs fall back to mailto:sales@quokkaq.com or local /{locale}/docs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional alias for the product app URL (same role as NEXT_PUBLIC_APP_URL).
# PUBLIC_APP_URL=http://localhost:3000
