# Base URL of the Go API: server-side fetch (plans) and browser lead form (POST /public/leads/request).
# Prefer MARKETING_API_URL in production for server-only fetch so the API URL is not required in the client bundle.
# If unset, NEXT_PUBLIC_API_URL is used. CORS on the API must allow this marketing origin.
# GET /public/marketing-stats (Orval) uses the same base when set.
# MARKETING_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Minimum active companies before the landing stats block shows the live count (default 10). Set 0 to always show when count is greater than zero.
# NEXT_PUBLIC_MARKETING_STATS_MIN_COMPANIES=10

# Cal.com embed for the Book demo section (full iframe src, often ends with ?embed=true).
# NEXT_PUBLIC_CALCOM_EMBED_SRC=https://cal.com/your-org/30min?embed=true

# Optional YouTube/Vimeo embed URL for the “Watch overview” control on the first interface showcase card.
# NEXT_PUBLIC_MARKETING_DEMO_VIDEO_EMBED=https://www.youtube-nocookie.com/embed/VIDEO_ID

# Canonical origin of this marketing site (no trailing slash). Used for metadata, OG URLs, sitemap, hreflang, and in-app Privacy Policy links (product app reads the same name).
# In development, if unset, http://localhost:3010 is used. On Vercel, VERCEL_URL is used when this is unset.
# Required for production builds outside Vercel (NODE_ENV=production) so metadata never falls back to localhost.
# Legacy alias: NEXT_PUBLIC_MARKETING_URL (same value; prefer NEXT_PUBLIC_MARKETING_SITE_URL).
# NEXT_PUBLIC_MARKETING_SITE_URL=https://quokkaq.com

# Base URL of the product web app (signup links on the pricing block).
# If unset, CTAs fall back to mailto:sales@quokkaq.com or local /{locale}/docs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional alias for the product app URL (same role as NEXT_PUBLIC_APP_URL).
# PUBLIC_APP_URL=http://localhost:3000

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). If unset, GTM is not loaded and the cookie banner is omitted unless extended later.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
