# Base URL of the Go API (server-side fetch for /subscriptions/plans via Orval).
# Prefer MARKETING_API_URL in production so the value is not exposed to the browser bundle.
# If unset, NEXT_PUBLIC_API_URL is used.
# MARKETING_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Base URL of the product web app (signup / contact links on the pricing block).
# If unset, CTAs fall back to mailto:sales@quokkaq.com or local /{locale}/docs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional alias for the product app URL (same role as NEXT_PUBLIC_APP_URL).
# PUBLIC_APP_URL=http://localhost:3000
