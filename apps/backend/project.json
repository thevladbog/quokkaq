{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend",
  "projectType": "application",
  "tags": ["type:app", "platform:backend", "lang:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/bin"],
      "options": {
        "command": "go build -o bin/server ./cmd/api",
        "cwd": "apps/backend"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/run-backend-dev.js",
        "cwd": "apps/backend",
        "usePty": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash -lc 'set -euo pipefail; mkdir -p test-results; if [ \"${CI:-}\" = \"true\" ]; then go run gotest.tools/gotestsum@v1.12.3 --junitfile test-results/go-junit.xml -- ./...; else go test ./...; fi'",
        "cwd": "apps/backend"
      }
    },
    "test-demoseed-smoke": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash -lc 'set -euo pipefail; if [ -z \"${DATABASE_URL:-}\" ]; then echo \"DATABASE_URL must be set (PostgreSQL 16+ DSN, empty DB)\" >&2; exit 1; fi; go test -tags=demoseed_integration -count=1 ./internal/demoseed/...'",
        "cwd": "apps/backend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4 run ./...",
        "cwd": "apps/backend"
      }
    },
    "lint:ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash -lc 'REF=\"${LINT_BASE_REF:-origin/main}\"; go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4 run ./... --new-from-rev=\"$REF\"'",
        "cwd": "apps/backend"
      }
    },
    "openapi": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/docs/swagger.json", "{projectRoot}/docs/openapi.json", "{projectRoot}/docs/swagger.yaml", "{projectRoot}/docs/docs.go"],
      "options": {
        "commands": [
          "go run github.com/swaggo/swag/cmd/swag@v1.16.6 init -g cmd/api/main.go -o ./docs",
          "go run ./cmd/swagger-to-openapi3"
        ],
        "cwd": "apps/backend",
        "parallel": false
      }
    },
    "openapi:check": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "go run github.com/swaggo/swag/cmd/swag@v1.16.6 init -g cmd/api/main.go -o ./docs",
          "go run ./cmd/swagger-to-openapi3",
          "git diff --exit-code docs/docs.go docs/swagger.json docs/openapi.json docs/swagger.yaml"
        ],
        "cwd": "apps/backend",
        "parallel": false
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t quokkaq-backend:latest .",
        "cwd": "apps/backend"
      }
    }
  }
}
