# Production Environment Variables for QuokkaQ Backend

# ============================================================================
# IMPORTANT: This file contains sensitive production credentials
# Copy this to .env.prod and fill in your actual values
# NEVER commit .env.prod to version control!
# ============================================================================

# Domain Configuration
# APP_BASE_URL should point to your FRONTEND URL (where users will register)
# Used for generating email invitation links (e.g., https://your-frontend.com/register/TOKEN)
APP_BASE_URL=https://quokkaq.v-b.tech

# Let's Encrypt
ACME_EMAIL=your-email@example.com

# Database Configuration
# Note: These are assembled into DATABASE_URL by docker-compose
# The app uses: postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123
POSTGRES_DB=quokkaq

# Redis Configuration
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_456

# MinIO / S3 Configuration
MINIO_ROOT_USER=CHANGE_THIS_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD_789
AWS_S3_BUCKET=quokkaq-materials

# SMTP Configuration (Email)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@quokkaq.v-b.tech
SMTP_SECURE=false

# JWT Configuration (CRITICAL - CHANGE THIS!)
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_USE_OPENSSL_RAND

# Optional: Application Environment
APP_ENV=production
