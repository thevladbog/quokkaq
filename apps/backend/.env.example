# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quokkaq

# Server Configuration
PORT=3001
APP_BASE_URL=http://localhost:3000

# CORS: comma-separated allowed origins (optional). If unset, defaults include localhost and quokkaq.v-b.tech hosts.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# GORM AutoMigrate on startup (set to false when using explicit migrations in production)
# RUN_AUTO_MIGRATE=false

# MinIO / AWS S3 Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=quokkaq-materials
AWS_ENDPOINT=http://localhost:9000
# AWS_PUBLIC_ENDPOINT - Public-facing URL for S3 (used in file URLs returned to clients)
# For production with Traefik: https://s3.quokkaq.v-b.tech
# For local development: leave empty or use http://localhost:9000
# AWS_PUBLIC_ENDPOINT=https://s3.yourdomain.com

# WebSocket Configuration
# WebSocket is served at /ws endpoint on the same server as the API
# Frontend should use:
#   - Production: wss://api.quokkaq.v-b.tech/ws
#   - Local development: ws://localhost:3001/ws
# Set NEXT_PUBLIC_WS_URL in the frontend environment variables

# SMTP Configuration (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com
SMTP_SECURE=false

# JWT Configuration (Optional)
# JWT_SECRET=your-super-secret-key-change-this-in-production

# JWT Configuration (for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: separate pepper for desktop terminal pairing-code digest (defaults to JWT_SECRET)
# TERMINAL_CODE_PEPPER=

# Redis Configuration (for background jobs)
# REDIS_URL=redis://localhost:6379/0

# Application Environment
# APP_ENV=development

# Platform / SaaS operator API (/platform/*): in non-production, allow tenant role "admin" when true (local dev).
# In production (APP_ENV=production) tenant admins are never allowed; use role platform_admin (see SETUP.md).
# PLATFORM_ALLOW_TENANT_ADMIN=true

# Billing / Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Set to false to disable wiring the Stripe provider even if STRIPE_SECRET_KEY is set
# BILLING_ENABLED=true
# Non-production only: return a mock checkout response when Stripe is not configured (never use in production)
# BILLING_MOCK_CHECKOUT=true

# DaData (optional): RU counterparty autocomplete — keys only on backend; see SETUP.md and docs/third-party/dadata/
# DADATA_API_KEY=
# Optional secret (if your DaData project uses it)
# DADATA_SECRET=
# Optional separate key for Cleaner API (defaults to DADATA_API_KEY)
# DADATA_CLEANER_API_KEY=
