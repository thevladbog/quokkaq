# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quokkaq

# Server Configuration
PORT=3001
# Public URL of this API (browser-accessible). Required for OIDC redirect_uri and SAML ACS/metadata — must be the Go origin the IdP redirects to (e.g. http://localhost:3001), not the Next.js port.
# If unset, defaults to http://localhost:3001 (APP_BASE_URL is not used here; it is often the SPA only).
API_PUBLIC_URL=http://localhost:3001
# Browser app origin for post-SSO redirect (one-time code → /{locale}/login/sso/callback).
PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Google Calendar OAuth (admin “Connect Google”). Redirect must match Google Cloud Console (path: /calendar-integrations/google/oauth/callback on the API origin).
# GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
# GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
# GOOGLE_CALENDAR_OAUTH_REDIRECT_URL=http://localhost:3001/calendar-integrations/google/oauth/callback

# CORS: comma-separated allowed origins (optional). If unset, defaults include localhost and quokkaq.v-b.tech hosts.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# GORM AutoMigrate on startup (set to false when using explicit migrations in production)
# RUN_AUTO_MIGRATE=false

# MinIO / AWS S3 Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=quokkaq-materials
AWS_ENDPOINT=http://localhost:9000
# AWS_PUBLIC_ENDPOINT — public base URL for S3 (used in file URLs returned to clients).
# If the backend runs in Docker, set this to what the browser uses (e.g. http://localhost:9000);
# docker-compose.yml defaults it for the backend container. Local process + MinIO on host: can stay unset if AWS_ENDPOINT is already http://localhost:9000.
# Production (Traefik): https://s3.yourdomain.com
# AWS_PUBLIC_ENDPOINT=https://s3.yourdomain.com

# WebSocket Configuration
# WebSocket is served at /ws endpoint on the same server as the API
# Frontend should use:
#   - Production: wss://api.quokkaq.v-b.tech/ws
#   - Local development: ws://localhost:3001/ws
# Set NEXT_PUBLIC_WS_URL in the frontend environment variables

# SMTP Configuration (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com
SMTP_SECURE=false
# Dev only: skip TLS certificate verification for SMTP (self-signed). Do not set in production.
# SMTP_TLS_INSECURE_SKIP_VERIFY=true

# JWT Configuration (Optional)
# JWT_SECRET=your-super-secret-key-change-this-in-production

# JWT Configuration (for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Per-tenant OIDC (SSO): encrypt IdP client_secret at rest (32-byte key, base64 or hex). If unset, a key is derived from JWT_SECRET (dev only).
# Same key encrypts Yandex CalDAV app passwords for unit calendar integration (/units/{id}/calendar-integration).
# SSO_SECRETS_ENCRYPTION_KEY=

# SAML SP signing (required when using company SSO protocol "saml"). PEM text; used to sign AuthnRequest and validate responses.
# Generate local dev certs: ../../tools/test-idp/generate-saml-sp-certs.sh
# SAML_SP_PRIVATE_KEY_PEM=
# SAML_SP_CERT_PEM=

# Locale segment in redirect after IdP login: /{locale}/login/sso/callback?code=… (e.g. ru, en).
# LOGIN_REDIRECT_LOCALE=en

# Optional: separate pepper for desktop terminal pairing-code digest (defaults to JWT_SECRET)
# TERMINAL_CODE_PEPPER=

# Redis Configuration (for background jobs and SSO OAuth state / PKCE / one-time exchange codes)
# REDIS_URL=redis://localhost:6379/0
# Asynq worker/client use REDIS_HOST / REDIS_PORT (default localhost:6379). In docker-compose, backend gets REDIS_HOST=redis.
# SSO requires Redis: set REDIS_URL or REDIS_HOST+REDIS_PORT (same as workers).

# Application Environment
# APP_ENV=development

# Logging: LOG_LEVEL=debug|info|warn|error (default info). LOG_FORMAT=json|text — json in production/staging when unset; text uses tinted console output in development.
# LOG_LEVEL=info
# LOG_FORMAT=text
# HTTP correlation: clients may send header X-Request-Id (optional); the API echoes it on the response and includes it in structured logs as request_id.
# W3C Trace Context: browsers may send traceparent (and optional tracestate); OpenTelemetry continues the trace on the server when OTEL is configured.

# OpenTelemetry traces (optional). If OTEL_EXPORTER_OTLP_ENDPOINT is unset, tracing export is disabled but W3C propagation still applies.
# OTLP HTTP (e.g. local Collector): default path /v1/traces is used by the exporter.
# OTEL_SERVICE_NAME=quokkaq-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: OTEL_TRACES_SAMPLER=parentbased_traceidratio, OTEL_TRACES_SAMPLER_ARG=0.1
# Local smoke test: run OpenTelemetry Collector + Jaeger or Grafana Tempo, send traffic with traceparent from the SPA, search traces by trace_id in the backend UI.
# With Next.js browser RUM (NEXT_PUBLIC_OTEL_ENABLED on the frontend), browser-exported spans and API spans can share the same trace_id when requests go through /api with propagated trace context.

# Platform / SaaS operator API (/platform/*): in non-production, allow tenant role "admin" when true (explicit opt-in).
# apps/backend docker-compose.yml defaults this to false; set PLATFORM_ALLOW_TENANT_ADMIN=true only when you intend tenant admins to use /platform locally.
# In production (APP_ENV=production) tenant admins are never allowed; use role platform_admin (see SETUP.md).
# PLATFORM_ALLOW_TENANT_ADMIN=true

# YooKassa — platform invoice payment links (POST /invoices/:id/yookassa-payment-link) and POST /webhooks/yookassa
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Optional separate secret for webhook HMAC (falls back to YOOKASSA_SECRET_KEY if unset)
# YOOKASSA_WEBHOOK_SECRET=
# Return URL after customer pays at YooKassa (redirect target)
# YOOKASSA_PAYMENT_RETURN_URL=https://your-app.example.com/organization/billing/invoices
# Used as fallback return URL if YOOKASSA_PAYMENT_RETURN_URL is empty
# PUBLIC_APP_URL=https://your-app.example.com

# Billing / Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Set to false to disable wiring the Stripe provider even if STRIPE_SECRET_KEY is set
# BILLING_ENABLED=true
# Non-production only: return a mock checkout response when Stripe is not configured (never use in production)
# BILLING_MOCK_CHECKOUT=true

# Support reports: external ticket backend (plane | yandex_tracker | unset = none). See docs/wiki/.../integrations/
# SUPPORT_REPORT_PLATFORM=yandex_tracker
# When using Yandex Tracker, set PLANE_ENABLED=false so Plane is not accidentally used.
# PLANE_ENABLED=true
#
# Plane (optional): support reports → work items when SUPPORT_REPORT_PLATFORM=plane
# PLANE_BASE_URL=https://plane.example.com
# PLANE_API_KEY=
# PLANE_WORKSPACE_SLUG=
# PLANE_PROJECT_ID=
# Dev / internal CA only: skip TLS verify when calling Plane (prefer trusting your CA on the host instead)
# PLANE_TLS_INSECURE_SKIP_VERIFY=true
#
# Yandex Tracker (optional): when SUPPORT_REPORT_PLATFORM=yandex_tracker
# Path to Yandex Cloud service account authorized key JSON (IAM via github.com/yandex-cloud/go-sdk/v2).
# When set, Bearer IAM is rotated automatically; YANDEX_TRACKER_TOKEN is ignored for Tracker API.
# See https://yandex.cloud/ru/docs/iam/operations/iam-token/create-for-sa#go_1
# Path is resolved from the API process working directory (nx serve / go run use apps/backend): use an absolute path,
# or a path relative to apps/backend. Repo-root temp/ (gitignored) from apps/backend, e.g.:
# YANDEX_TRACKER_SA_KEY_FILE=../../temp/yandex-sa-key.json
# YANDEX_TRACKER_SA_KEY_FILE=/secure/path/authorized_key.json
# YANDEX_TRACKER_TOKEN=
# YANDEX_TRACKER_ORG_ID=
# YANDEX_TRACKER_QUEUE=
# Optional: support-report queue when deployment_saas_settings.support_tracker_queue is empty (in-app support tickets).
# Optional: leads queue when deployment_saas_settings.leads_tracker_queue is empty (marketing + signup Tracker tickets).
# YANDEX_TRACKER_LEADS_QUEUE=
#
# Marketing lead form (POST /public/leads/request) needs Tracker credentials (YANDEX_TRACKER_ORG_ID + token or SA key)
# and a non-empty leads queue (DB deployment_saas_settings.leads_tracker_queue or YANDEX_TRACKER_LEADS_QUEUE).
# On 502, check API logs for "PostPublicLeadRequest: CreateLeadRequest:".
# Optional: JSON error detail in response for local debugging (not with APP_ENV=production):
# PUBLIC_LEAD_DEBUG=1
# Use X-Cloud-Org-ID instead of X-Org-ID when the org is linked to Yandex Cloud
# YANDEX_TRACKER_USE_CLOUD_ORG_ID=false
# OAuth (default) or static Bearer (only when SA key file is NOT set): YANDEX_TRACKER_AUTH_SCHEME=OAuth
# Optional override: YANDEX_TRACKER_API_BASE=https://api.tracker.yandex.net
#
# Optional: comment text when the user marks a report as not relevant (default is Russian)
# Optional: comment text posted to the external ticket when a report is marked not relevant (default is a short, applicant-facing message in Russian).
# SUPPORT_REPORT_CANCEL_COMMENT=

# DaData (optional): RU counterparty autocomplete — keys only on backend; see SETUP.md and docs/third-party/dadata/
# DADATA_API_KEY=
# Optional secret (if your DaData project uses it)
# DADATA_SECRET=
# Required for DaData Cleaner (address normalization); not inferred from DADATA_API_KEY
# DADATA_CLEANER_API_KEY=
