{
  "name": "kiosk-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/kiosk-desktop",
  "projectType": "application",
  "tags": ["type:app", "platform:desktop", "lang:rust", "lang:go"],
  "targets": {
    "build:agent": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src-tauri/binaries"],
      "options": {
        "command": "node scripts/build-agent.mjs",
        "cwd": "apps/kiosk-desktop"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:agent"],
      "options": {
        "command": "npm run tauri dev",
        "cwd": "apps/kiosk-desktop"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:agent"],
      "outputs": ["{projectRoot}/src-tauri/target/release"],
      "options": {
        "command": "npm run tauri build",
        "cwd": "apps/kiosk-desktop"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:agent"],
      "options": {
        "command": "cargo clippy",
        "cwd": "apps/kiosk-desktop/src-tauri"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:agent"],
      "options": {
        "command": "bash -lc 'set -euo pipefail; if command -v cargo-nextest >/dev/null 2>&1; then cargo nextest run --profile ci; else cargo test; fi'",
        "cwd": "apps/kiosk-desktop/src-tauri"
      }
    }
  }
}
