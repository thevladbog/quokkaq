# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: marketing site origin for “Contact us” on in-app pricing (scrolls to #book-demo where the lead form lives). If unset, mailto:sales@quokkaq.com is used.
# NEXT_PUBLIC_MARKETING_URL=http://localhost:3010
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Server-only: where Next.js proxies /api/* (see app/api/[[...path]]/route.ts and lib/api-upstream-proxy.ts).
# Priority: API_UPSTREAM_URL → NEXT_PUBLIC_API_URL → http://127.0.0.1:3001
# If NEXT_PUBLIC_API_URL points at a stale or different port than your running Go API, statistics and other new routes will 404 from /api — set API_UPSTREAM_URL to the real API base or align the port.
# API_UPSTREAM_URL=http://127.0.0.1:3001

# Server-only: optional extra hostnames (no port) for /api/kiosk-print-logo — must match logo URL origin exactly; use full URL envs above when using non-default ports.
# Loopback is not implicit: if logo URLs use http://127.0.0.1:PORT, set NEXT_PUBLIC_API_URL (or AWS_PUBLIC_ENDPOINT) to that same origin so it is allowlisted.
# Path must include /public/logos/ or /public/printer-logos/ (same as storage keys). No user-controlled host without an allowlisted origin.
# PRINT_ASSET_ALLOWED_HOSTS=s3.example.com
# Same as backend when Next must allow fetching logos from your public object storage host:
# AWS_PUBLIC_ENDPOINT=https://s3.example.com

# Tracing: either manual W3C headers on /api (default) or full browser RUM (OpenTelemetry).
# When NEXT_PUBLIC_OTEL_ENABLED=true, fetch is instrumented; do not set manual traceparent (handled by OTel).
# NEXT_PUBLIC_OTEL_ENABLED=false
# NEXT_PUBLIC_OTEL_SERVICE_NAME=quokkaq-web
# NEXT_PUBLIC_OTEL_TRACES_SAMPLER_RATIO=1
# NEXT_PUBLIC_OTEL_DOCUMENT_LOAD=false
# Direct OTLP from the browser (requires CORS on the collector). If unset, export goes to same-origin POST /api/telemetry/traces (see server env below).
# NEXT_PUBLIC_OTEL_EXPORTER_URL=http://localhost:4318/v1/traces
# Optional ingest key (must match OTEL_BROWSER_INGEST_SECRET on the server). This is not a security boundary: it is exposed to the
# browser (NEXT_PUBLIC_*) and only enables lightweight gating by matching a request header—not confidentiality or strong access control.
# The same-origin POST /api/telemetry/traces route uses that header only as a routing key (401 if wrong when OTEL_BROWSER_INGEST_SECRET is set),
# plus basic abuse controls (per-IP / per-key rate limits, max body size, OTLP JSON shape check)—not a substitute for real auth or network controls.
# NEXT_PUBLIC_OTEL_BROWSER_INGEST_KEY=
#
# Server-only (Next route app/api/telemetry/traces): forward browser OTLP JSON to the collector.
# OTEL_BROWSER_INGEST_UPSTREAM=http://127.0.0.1:4318/v1/traces
# Or reuse the same base as the Go API: OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Optional: reject ingest without header x-otel-ingest-key (same value as NEXT_PUBLIC_OTEL_BROWSER_INGEST_KEY). Routing key only—see note above.
# OTEL_BROWSER_INGEST_SECRET=
# Optional tuning (defaults are safe for dev): OTEL_BROWSER_INGEST_MAX_BODY_BYTES, OTEL_BROWSER_INGEST_RATE_WINDOW_MS,
# OTEL_BROWSER_INGEST_RATE_LIMIT_IP, OTEL_BROWSER_INGEST_RATE_LIMIT_KEY
# When behind a trusted reverse proxy only: set OTEL_BROWSER_INGEST_TRUST_FORWARDED_HEADERS=true so x-forwarded-for / x-real-ip are used for rate-limit keys (otherwise spoofable; defaults to a single "unknown" bucket).
#
# End-to-end: enable OTEL on the Go API (OTEL_EXPORTER_OTLP_ENDPOINT), enable NEXT_PUBLIC_OTEL_ENABLED, configure ingest, open the app, confirm browser + server spans share trace_id in Jaeger/Tempo.

# Optional: Sentry, Analytics, etc.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_GA_ID=
