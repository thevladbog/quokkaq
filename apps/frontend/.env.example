# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Server-only: where Next.js proxies /api/* (see app/api/[[...path]]/route.ts and lib/api-upstream-proxy.ts).
# Priority: API_UPSTREAM_URL → NEXT_PUBLIC_API_URL → http://127.0.0.1:3001
# If NEXT_PUBLIC_API_URL points at a stale or different port than your running Go API, statistics and other new routes will 404 from /api — set API_UPSTREAM_URL to the real API base or align the port.
# API_UPSTREAM_URL=http://127.0.0.1:3001

# Server-only: optional extra hostnames (no port) for /api/kiosk-print-logo — must match logo URL origin exactly; use full URL envs above when using non-default ports.
# Loopback is not implicit: if logo URLs use http://127.0.0.1:PORT, set NEXT_PUBLIC_API_URL (or AWS_PUBLIC_ENDPOINT) to that same origin so it is allowlisted.
# Path must include /public/logos/ or /public/printer-logos/ (same as storage keys). No user-controlled host without an allowlisted origin.
# PRINT_ASSET_ALLOWED_HOSTS=s3.example.com
# Same as backend when Next must allow fetching logos from your public object storage host:
# AWS_PUBLIC_ENDPOINT=https://s3.example.com

# Optional: Sentry, Analytics, etc.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_GA_ID=
