# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Server-only: where Next.js proxies /api/* (see app/api/[[...path]]/route.ts). Defaults to NEXT_PUBLIC_API_URL, then http://127.0.0.1:3001. Set if Go API listens on another host/port (e.g. Docker).
# API_UPSTREAM_URL=http://127.0.0.1:3001

# Server-only: optional extra hostnames allowed for /api/kiosk-print-logo (MinIO/S3 logo URLs for thermal print).
# PRINT_ASSET_ALLOWED_HOSTS=s3.example.com
# Same as backend when Next must allow fetching logos from your public object storage host:
# AWS_PUBLIC_ENDPOINT=https://s3.example.com
# Optional: allow any https URL whose path contains /public/logos/ (uploads from this app). SSRF risk on untrusted networks.
# PRINT_ASSET_ALLOW_PUBLIC_LOGO_PATHS=true

# Optional: Sentry, Analytics, etc.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_GA_ID=
