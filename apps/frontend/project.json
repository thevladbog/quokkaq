{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend",
  "projectType": "application",
  "tags": ["type:app", "platform:web"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "apps/frontend"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "command": "next build",
        "cwd": "apps/frontend"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start",
        "cwd": "apps/frontend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "apps/frontend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/frontend"
      }
    },
    "test-a11y": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm test:a11y",
        "cwd": "apps/frontend"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check .",
        "cwd": "apps/frontend"
      }
    },
    "format:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write .",
        "cwd": "apps/frontend"
      }
    },
    "orval": {
      "executor": "nx:run-commands",
      "options": {
        "command": "orval --config orval.config.ts",
        "cwd": "apps/frontend"
      }
    },
    "orval:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "orval --config orval.config.ts && untracked=$(git ls-files --others --exclude-standard -- lib/api/generated/) && if [ -n \"$untracked\" ]; then echo 'Untracked files under lib/api/generated/ (run from repo root or commit generated output):' && echo \"$untracked\" && exit 1; fi && git diff --exit-code lib/api/generated/",
        "cwd": "apps/frontend"
      }
    }
  }
}
