# Pin the public npm registry to ensure consistent dependency resolution
# across all machines and prevent accidental use of private mirrors
registry=https://registry.npmjs.org/

# Strict peer dependencies (recommended for monorepos)
# strict-peer-dependencies=false

# Auto-install peers (optional, can help with some packages)
# auto-install-peers=true

# Shamefully hoist (for compatibility with some tools)
# shamefully-hoist=true
