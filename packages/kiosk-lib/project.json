{
  "name": "kiosk-lib",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/kiosk-lib/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:kiosk"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p tsconfig.json",
        "cwd": "packages/kiosk-lib"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Linting kiosk-lib'",
        "cwd": "packages/kiosk-lib"
      }
    }
  }
}
