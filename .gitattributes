# Ensure consistent line endings across platforms
* text=auto

# Force LF for lockfiles to prevent corruption
pnpm-lock.yaml text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf

# Shell scripts
*.sh text eol=lf

# Force LF for source code
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
